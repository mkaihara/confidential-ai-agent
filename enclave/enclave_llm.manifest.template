libos.entrypoint = "{{ entrypoint }}"

loader.log_level = "error"

loader.argv = ["python3", "enclave_llm.py"]

loader.env.LD_LIBRARY_PATH = "/lib:{{ arch_libdir }}"
loader.env.HOME = "/home/azureuser"
loader.env.ENCLAVE_PORT = "7777"
loader.env.PYTHONPATH = "/enclave/.venv/lib/python3.12/site-packages"
loader.env.PYTHONHOME = ""
loader.env.WRAP_KEY_HEX = { passthrough = true }

fs.mounts = [
  { path = "/lib",              uri = "file:{{ gramine.runtimedir() }}" },
  { path = "{{ arch_libdir }}", uri = "file:{{ arch_libdir }}" },
  { path = "/usr",              uri = "file:/usr" },
  { path = "/etc",              uri = "file:/etc" },
  { path = "/enclave",          uri = "file:." },
  { path = "/secrets", uri = "file:/home/azureuser/confidential-ai/secrets", type = "encrypted", key_name = "api_key" },
  { path = "/sealed",  uri = "file:/home/azureuser/confidential-ai/sealed",  type = "encrypted", key_name = "_sgx_mrenclave" },
]

sys.insecure__allow_eventfd = true

sgx.debug = true
sgx.remote_attestation = "dcap"
sgx.edmm_enable = false
sgx.enclave_size = "512M"
sgx.max_threads = 8

sgx.trusted_files = [
  "file:{{ gramine.runtimedir() }}/",
  "file:{{ arch_libdir }}/",
  "file:/usr/lib/x86_64-linux-gnu/",
  "file:/usr/lib/python3.12/",
  "file:/usr/lib/python3/",
  "file:/usr/bin/python3.12",
  "file:enclave_llm.py",
  "file:.venv/lib/python3.12/site-packages/anthropic/",
  "file:.venv/lib/python3.12/site-packages/httpx/",
  "file:.venv/lib/python3.12/site-packages/httpcore/",
  "file:.venv/lib/python3.12/site-packages/certifi/",
  "file:.venv/lib/python3.12/site-packages/certifi/cacert.pem",
  "file:.venv/lib/python3.12/site-packages/anyio/",
  "file:.venv/lib/python3.12/site-packages/sniffio/",
  "file:.venv/lib/python3.12/site-packages/idna/",
  "file:.venv/lib/python3.12/site-packages/h11/",
  "file:.venv/lib/python3.12/site-packages/pydantic/",
  "file:.venv/lib/python3.12/site-packages/pydantic_core/",
  "file:.venv/lib/python3.12/site-packages/annotated_types/",
  "file:.venv/lib/python3.12/site-packages/distro/",
  "file:.venv/lib/python3.12/site-packages/jiter/",
  "file:.venv/lib/python3.12/site-packages/typing_extensions.py",
  "file:.venv/lib/python3.12/site-packages/docstring_parser/",
  "file:.venv/lib/python3.12/site-packages/typing_inspection/",
  "file:.venv/lib/python3.12/site-packages/cryptography/",
  "file:.venv/lib/python3.12/site-packages/_cffi_backend.cpython-312-x86_64-linux-gnu.so",
  "file:.venv/lib/python3.12/site-packages/cryptography/hazmat/bindings/_rust.abi3.so",
  "file:.venv/lib/python3.12/site-packages/jiter/jiter.cpython-312-x86_64-linux-gnu.so",
  "file:.venv/lib/python3.12/site-packages/pydantic_core/_pydantic_core.cpython-312-x86_64-linux-gnu.so",
]

sgx.allowed_files = [
  "file:/etc/resolv.conf",
  "file:/etc/hosts",
  "file:/etc/host.conf",
  "file:/etc/nsswitch.conf",
  "file:/etc/os-release",
  "file:/etc/gai.conf",
  "file:/dev/attestation/user_report_data",
  "file:/dev/attestation/report",
  "file:/dev/attestation/quote",
  "file:/dev/attestation/attestation_type",
  "file:/dev/attestation/keys/api_key",
]
